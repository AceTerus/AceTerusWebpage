{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(?:webp|png|jpg|jpeg|gif|svg|ico|woff2|woff|mp4|webm))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(?:js|css))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*\\.(html|png|jpg|svg|ico|gif|webp|js|css|woff2?|txt|xml|mp4|webm|ogg|mov)$)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/admin.html",
      "has": [{ "type": "host", "value": "admin.aceterus.com" }]
    },
    {
      "src": "/(.*)",
      "dest": "/events.html",
      "has": [{ "type": "host", "value": "events.aceterus.com" }]
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
